// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  TRAINER
  STUDENT
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// Models
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  trainerProfile  Trainer?
  studentProfile  Student?
  refreshTokens   RefreshToken[]

  @@map("users")
}

model Trainer {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  students           Student[]
  routines           Routine[]
  routineTemplates   RoutineTemplate[]
  exerciseTemplates  ExerciseTemplate[]

  @@map("trainers")
}

model Student {
  id        String  @id @default(uuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id])

  age    Int?
  weight Float?
  height Float?
  goal   String?

  // Relations
  routines Routine[]

  @@map("students")
}

model ExerciseTemplate {
  id          String      @id @default(uuid())
  name        String
  description String
  videoUrl    String?
  imageUrl    String?
  category    String?
  muscleGroup String?
  equipment   String?
  difficulty  Difficulty?
  trainerId   String
  trainer     Trainer     @relation(fields: [trainerId], references: [id])
  createdAt   DateTime    @default(now())

  // Relations
  routineTemplateExercises RoutineTemplateExercise[]

  @@map("exercise_templates")
}

model RoutineTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String?
  trainerId   String
  trainer     Trainer  @relation(fields: [trainerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  exercises RoutineTemplateExercise[]

  @@map("routine_templates")
}

model RoutineTemplateExercise {
  id                String           @id @default(uuid())
  routineTemplateId String
  routineTemplate   RoutineTemplate  @relation(fields: [routineTemplateId], references: [id], onDelete: Cascade)
  exerciseTemplateId String
  exerciseTemplate  ExerciseTemplate @relation(fields: [exerciseTemplateId], references: [id])

  order       Int
  sets        Int?
  repetitions Int?
  weight      Float?
  duration    Int? // in seconds
  restTime    Int? // in seconds
  notes       String?

  @@unique([routineTemplateId, exerciseTemplateId])
  @@map("routine_template_exercises")
}

model Routine {
  id          String    @id @default(uuid())
  name        String
  description String?
  dayOfWeek   DayOfWeek
  trainerId   String
  trainer     Trainer   @relation(fields: [trainerId], references: [id])
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  exercises RoutineExercise[]

  @@map("routines")
}

model Exercise {
  id          String  @id @default(uuid())
  name        String
  description String
  videoUrl    String?
  imageUrl    String?

  // Relations
  routineExercises RoutineExercise[]

  @@map("exercises")
}

model RoutineExercise {
  id         String   @id @default(uuid())
  routineId  String
  routine    Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  order       Int
  sets        Int?
  repetitions Int?
  weight      Float?
  duration    Int? // in seconds
  restTime    Int? // in seconds
  notes       String?

  @@unique([routineId, exerciseId])
  @@map("routine_exercises")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}
